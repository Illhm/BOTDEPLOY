# Telegram API Credentials
# Get these from https://my.telegram.org/apps
API_ID=
API_HASH=

# Get this from @BotFather on Telegram
BOT_TOKEN=

# Security Settings
# Whitelist of Telegram user IDs allowed to use the bot
# Comma-separated list of IDs, e.g. 123456789,987654321
ALLOWED_USERS=

# Token for shutdown endpoint authentication
SHUTDOWN_TOKEN=

# Modal sets PORT automatically if using @modal.web_server, but for webhooks or standard config:
# FLASK_PORT=5000
